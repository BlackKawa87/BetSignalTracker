# ─────────────────────────────────────────────────────────────
# BetSignalTracker — Production Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to git.
# In Vercel: add each variable via Dashboard → Settings → Env Vars
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/<your-project>/settings/api

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # service_role key (backend only — NEVER expose in frontend)

# Frontend (prefix with VITE_ for Vite to embed at build time)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...     # anon/public key (safe for frontend)

# ── Telegram ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# Secret token sent in X-Telegram-Bot-Api-Secret-Token header
# Generate with: openssl rand -hex 32
# Set this SAME value when calling setWebhook with secret_token parameter
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here_min_32_chars

# Public URL of your Vercel deployment (used to auto-configure webhook)
PUBLIC_WEBHOOK_URL=https://your-project.vercel.app

# ── OpenAI ────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
# Used for: Signal AI Parser (gpt-4o-mini) + Image OCR (gpt-4o)
OPENAI_API_KEY=sk-proj-...

# ── Sports API ────────────────────────────────────────────────
# https://rapidapi.com/api-sports/api/api-football
# Free tier: 100 req/day — enough for personal use
SPORTS_API_KEY=your_rapidapi_key_here

# ── Cron Security ─────────────────────────────────────────────
# Optional: protects the manual /api/autoclose/run endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
